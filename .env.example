# Firebase Configuration (client — from Firebase Console → Project settings → Your apps)
# Full guide: docs/FIREBASE_SETUP.md
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Service Account (server-side only — gallery, upload, admin APIs)
# Option A: separate vars (private key: use \n for newlines in .env.local)
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
# Option B (Vercel-friendly): entire JSON from Service Accounts → Generate key
# FIREBASE_SERVICE_ACCOUNT_KEY=

# Google Gemini API
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=
# Native image generation model (must end with -image)
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Email Configuration (Optional)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Preset: Google I/O Connect Berlin 2026 (default) ───────────────────────
APP_PRESET=io-connect-2026

# ─── Branding overrides (optional) ───────────────────────────────────────────
# APP_EVENT_TITLE=Google I/O Connect Photo Booth
# APP_EVENT_SUBTITLE=Berlin 2026 · GDG London
# APP_EVENT_TAGLINE=Berlin · 2026
# APP_EVENT_LOCATION=Berlin
# APP_EVENT_DATE=2026
# APP_EVENT_URL=https://rsvp.withgoogle.com/events/ioconnect-berlin-2026
# APP_LOGO_PATH=/branding/gdg-london-berlin-2026.png
# APP_BACKDROP_PATH=/branding/page-backdrop-official.jpg
# APP_WATERMARK_TEXT=I/O CONNECT
# APP_PHOTO_CODE_PREFIX=IO26
# APP_STORAGE_PREFIX=io-connect-2026
# APP_COPYRIGHT_HOLDER=GDG London
# APP_META_DESCRIPTION=AI photo booth for Google I/O Connect Berlin 2026 — GDG London

# ─── API security (recommended for public Vercel deploys) ─────────────────────
# API_SECRET=

# Feature flags (optional)
# NEXT_PUBLIC_ENABLE_GALLERY=true
# NEXT_PUBLIC_ENABLE_ADMIN=true
# NEXT_PUBLIC_ENABLE_SUMMARY=true
NEXT_PUBLIC_ENABLE_EMAIL_SHARING=false
NEXT_PUBLIC_ENABLE_LINKEDIN_SHARE=true

# LinkedIn share (OAuth + AI caption + image post)
# Create app: https://www.linkedin.com/developers/apps — add "Share on LinkedIn" product
# Redirect URL: https://YOUR_DOMAIN/api/linkedin/callback
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_REDIRECT_URI=

# Admin moderation (server-only; /admin gallery moderation)
# ADMIN_SECRET=
