# Firebase Configuration — project ioconnect2026, web app GoogleIOConnect2026
# Full guide: docs/FIREBASE_SETUP.md
# Console: https://console.firebase.google.com/project/ioconnect2026
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=ioconnect2026.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=ioconnect2026
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=ioconnect2026.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=667745049577
NEXT_PUBLIC_FIREBASE_APP_ID=1:667745049577:web:e4972c5a5fd6ad04678978
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-T6NNHMY2JX

# Firebase Service Account (Server-side only — REQUIRED on Vercel for /api/gallery, upload, admin)
# MUST be from ioconnect2026 (not another Firebase project)
# Option A: separate vars (paste private key with \n for newlines)
FIREBASE_PROJECT_ID=ioconnect2026
FIREBASE_STORAGE_BUCKET=ioconnect2026.firebasestorage.app
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@ioconnect2026.iam.gserviceaccount.com
# Option B (Vercel-friendly): entire JSON from Firebase Console → Service Accounts → Generate key
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Google Gemini API
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
# Native image generation model (must end with -image)
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Email Configuration (Optional)
SENDGRID_API_KEY=your_sendgrid_key_here
SENDGRID_FROM_EMAIL=noreply@youremail.com

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Preset (gallery, admin, summary, standalone are built into io-connect-2026) ─
APP_PRESET=io-connect-2026
# APP_RUNTIME_MODE=standalone         # Only needed for Sitecore Marketplace embed

# ─── Branding (generic / white-label) ───────────────────────────────────────
# APP_EVENT_TITLE=AI Photo Booth
# APP_EVENT_SUBTITLE=Create Your Memory
# APP_EVENT_TAGLINE=Capture · transform · share
# APP_EVENT_LOCATION=
# APP_EVENT_DATE=
# APP_EVENT_URL=
# APP_LOGO_PATH=/branding/sitecore-silver-logo-official.png
# APP_BACKDROP_PATH=/branding/page-backdrop-official.jpg
# APP_WATERMARK_TEXT=AI PHOTO BOOTH
# APP_PHOTO_CODE_PREFIX=PHOTO
# APP_STORAGE_PREFIX=photo-booth
# APP_COPYRIGHT_HOLDER=Photo Booth
# APP_META_DESCRIPTION=Capture, transform, and share AI-powered event photos
# APP_SITECORE_BRAND_RULES=true       # Enable Sitecore AI guardrails in Gemini

# ─── API security (recommended for public Vercel deploys) ─────────────────────
# API_SECRET=choose-a-long-random-string

# ─── Sitecore Authoring API (required for attendee page sync in Marketplace) ─
# CM hostname — same Deploy → Credentials screen as the automation client
# XMC_HOST=your_cm_hostname.sitecorecloud.io
# SITECORE_CLIENT_ID=automation_client_id
# SITECORE_CLIENT_SECRET=automation_client_secret
# SITECORE_SITE_PATH=/sitecore/content/sitecoresilver/sitecoresilver
# SITECORE_ATTENDEES_PARENT_PATH=/sitecore/content/sitecoresilver/sitecoresilver/Home/SilverAttendees
# SITECORE_ATTENDEE_TEMPLATE_ID={B574DCCF-0001-400D-8010-000000010112}
# SITECORE_ATTENDEE_SYNC=true
# NEXT_PUBLIC_ENABLE_SITECORE_ATTENDEE_PAGES=true

# Feature flags (optional — ignored when APP_PRESET=io-connect-2026)
# NEXT_PUBLIC_ENABLE_GALLERY=true
# NEXT_PUBLIC_ENABLE_ADMIN=true
# NEXT_PUBLIC_ENABLE_SUMMARY=true
NEXT_PUBLIC_ENABLE_EMAIL_SHARING=false
NEXT_PUBLIC_ENABLE_LINKEDIN_SHARE=true

# LinkedIn share (OAuth + AI caption + image post)
# Create app: https://www.linkedin.com/developers/apps — add "Share on LinkedIn" product
# Redirect URL: https://YOUR_DOMAIN/api/linkedin/callback
# LINKEDIN_CLIENT_ID=your_client_id
# LINKEDIN_CLIENT_SECRET=your_client_secret
# LINKEDIN_REDIRECT_URI=https://copenhagen-silver.vercel.app/api/linkedin/callback

# Admin moderation (server-only; used for /admin gallery moderation)
ADMIN_SECRET=choose-a-strong-password-for-event-staff
